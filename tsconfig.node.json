{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "lib": ["ES2022", "ESNext.Disposable"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@uix/api": ["./src/api/index.ts"],
      "@uix/api/*": ["./src/api/*.ts"],
      "#backend/*": ["./src/main/*"],
      "#features/*": ["./src/features/*"],
      "#shared/*": ["./src/shared/*"]
    }
  },
  "include": [
    "src/api/**/*.ts",
    "src/main/**/*.ts",
    "src/features/**/backend/**/*.ts",
    "src/features/**/shared/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts",
    "electron.vite.config.ts",
    "vitest.config.mts"
  ],
  // workspace.ts is the web-only half of @uix/api (React surfaces,
  // CSSStyleSheet); nothing in the main process imports it, and it needs
  // the DOM lib this config deliberately lacks.
  "exclude": ["src/api/workspace.ts"]
}
