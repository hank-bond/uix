{
  "name": "uix",
  "version": "0.0.0",
  "private": true,
  "description": "Minimal protocol + cockpit for agent ↔ HTML ↔ human interfaces. See AGENTS.md.",
  "main": "out/main/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docs:index": "node scripts/docs-index.mjs",
    "docs:check": "node scripts/docs-index.mjs --check",
    "test": "vitest run",
    "prepare": "git config core.hooksPath .githooks || true",
    "check": "npm run typecheck && npm run lint && npm run test && npm run format:check && npm run docs:check"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.77.0",
    "jiti": "^2.7.0",
    "pino": "^10.3.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^35.7.5",
    "electron-vite": "^2.3.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.60.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
